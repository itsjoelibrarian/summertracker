<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Staff Console — Summer Reading Smackdown</title>
<style>
/* ── Reset & Root ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root {
  --navy: #0A142A;
  --navy-mid: #14244C;
  --red: #8B0000;
  --red-mid: #A31D1D;
  --blue: #0F3D7A;
  --blue-light: #EEF4FC;
  --blue-mid: #124E96;
  --gold: #C6920E;
  --gold-light: #FCF7EB;
  --white: #FFFFFF;
  --off: #F4F6F9;
  --text: #161616;
  --muted: #4D4D4D;
  --border: #D1C7BD;
  --green: #1B5E20;
  --green-light: #E8F5E9;
  --r: 8px;
  --rl: 12px;
  --shadow: 0 2px 8px rgba(0,0,0,0.08);
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--off);color:var(--text);min-height:100vh;font-size:15px}
.app{max-width:900px;margin:0 auto;padding:20px 10px 40px}
.page{display:none}.page.active{display:block}

/* ── Header ── */
.hdr{background:var(--navy);color:#fff;padding:20px;border-radius:var(--rl);margin-bottom:20px;border-bottom:4px solid var(--gold);position:relative}
.hdr h1{font-size:22px;font-weight:800;letter-spacing:-0.5px}
.hdr p{font-size:13px;color:rgba(255,255,255,0.8);margin-top:2px}
.logout-btn{position:absolute;right:20px;top:22px;background:transparent;border:1px solid rgba(255,255,255,0.5);color:#fff;padding:5px 12px;font-size:12px;border-radius:6px;font-weight:600;cursor:pointer}
.logout-btn:hover{background:rgba(255,255,255,0.1)}

/* ── Layout Panels ── */
.grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:768px){.grid{grid-template-columns:1fr}}
.card{background:#fff;border:1px solid var(--border);border-radius:var(--rl);padding:20px;box-shadow:var(--shadow);margin-bottom:20px}
.card-title{font-size:16px;font-weight:700;color:var(--navy);margin-bottom:15px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--off);padding-bottom:8px}

/* ── Forms & UI ── */
.fg{margin-bottom:14px}
.lbl{display:block;font-size:12px;font-weight:700;color:var(--muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px}
.inp{width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:var(--r);font-size:15px}
.inp:focus{border-color:var(--blue-mid);outline:none}
.btn{padding:10px 16px;border-radius:var(--r);font-size:14px;font-weight:700;cursor:pointer;border:none;display:inline-flex;align-items:center;gap:6px;justify-content:center}
.btn-navy{background:var(--navy);color:#fff}.btn-navy:hover{background:var(--navy-mid)}
.btn-gold{background:var(--gold);color:var(--navy)}.btn-gold:hover{opacity:.9}
.btn-full{width:100%}

/* ── Feedback Boxes ── */
.err{background:#FDF1F1;color:var(--red);border:1px solid var(--red-mid);border-radius:var(--r);padding:10px;font-size:13px;font-weight:600;margin-bottom:12px}
.ok{background:var(--green-light);color:var(--green);border:1px solid var(--green);border-radius:var(--r);padding:10px;font-size:13px;font-weight:600;margin-bottom:12px}

/* ── Search & Results UI ── */
.search-box{display:flex;gap:8px}
.patron-info-box{background:var(--blue-light);border:1px solid rgba(18,78,150,0.15);border-radius:var(--r);padding:12px;margin-bottom:14px}
.p-name{font-size:16px;font-weight:700;color:var(--navy)}
.p-meta{font-size:13px;color:var(--muted);margin-top:2px}

/* ── Simple Punch Tracker Items ── */
.b-item{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;background:var(--off);border-radius:var(--r);margin-bottom:6px;font-size:13px}
.b-title{font-weight:700;color:var(--navy)}
.badge{font-size:10px;padding:2px 6px;border-radius:4px;font-weight:700;color:#fff;margin-left:6px}
.badge-r{background:var(--red-mid)}
.badge-b{background:var(--blue-mid)}
</style>
</head>
<body>
<div class="app">

  <div id="page-auth" class="page active">
    <div class="card" style="max-width:400px;margin:60px auto 0;text-align:center">
      <h2 style="color:var(--navy);margin-bottom:4px">Staff Console Access</h2>
      <p style="color:var(--muted);font-size:13px;margin-bottom:20px">Please log in using authorized staff credentials.</p>
      <div class="err" id="auth-err" style="display:none"></div>
      <form id="staff-login-form">
        <div class="fg" style="text-align:left"><label class="lbl">Email Address</label><input class="inp" id="auth-email" type="email" placeholder="staff@sewardlibrary.org" autocomplete="username" required/></div>
        <div class="fg" style="text-align:left"><label class="lbl">Password</label><input class="inp" id="auth-pass" type="password" placeholder="••••••••" autocomplete="current-password" required/></div>
        <button class="btn btn-navy btn-full" id="btn-login" type="submit">Verify Credentials</button>
      </form>
    </div>
  </div>

  <div id="page-main" class="page">
    <div class="hdr">
      <h1>Smackdown Administration</h1>
      <p>Authorized Seward Memorial Library Staff Toolkit</p>
      <button class="logout-btn" id="btn-logout">Exit Session</button>
    </div>

    <div class="grid">
      <div>
        <div class="card">
          <div class="card-title">📝 Update York Metrics</div>
          <p style="font-size:13px;color:var(--muted);margin-bottom:14px">Sync metrics extracted directly from the exterior ReaderZone system parameters.</p>
          <div class="err" id="york-err" style="display:none"></div>
          <div class="ok" id="york-ok" style="display:none"></div>
          <div class="fg"><label class="lbl">Total Books Logged by York</label><input class="inp" id="york-books" type="number" placeholder="e.g. 1420"/></div>
          <div class="fg"><label class="lbl">Total Active York Readers</label><input class="inp" id="york-readers" type="number" placeholder="e.g. 185"/></div>
          <button class="btn btn-navy btn-full" id="btn-update-york">💾 Push live to leaderboard</button>
        </div>
      </div>

      <div>
        <div class="card">
          <div class="card-title">🔍 Patron Audit & Look-up</div>
          <div class="fg">
            <label class="lbl">Enter Library Card Number</label>
            <div class="search-box">
              <input class="inp" id="search-card" type="text" placeholder="e.g. 12345" maxlength="5"/>
              <button class="btn btn-gold" id="btn-search-patron">Search</button>
            </div>
          </div>
          
          <div id="search-results" style="margin-top:15px;display:none">
            <div class="patron-info-box">
              <div class="p-name" id="res-name">--</div>
              <div class="p-meta" id="res-card">Card #--</div>
            </div>
            
            <div style="margin-bottom:10px;font-size:13px;font-weight:700;color:var(--navy)">Metrics Dashboard:</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:15px;text-align:center">
              <div style="background:var(--off);padding:8px;border-radius:var(--r)"><div style="font-size:18px;font-weight:800" id="res-punches">0</div><div style="font-size:11px;color:var(--muted)">Total Punches</div></div>
              <div style="background:var(--off);padding:8px;border-radius:var(--r)"><div style="font-size:18px;font-weight:800" id="res-entries">0</div><div style="font-size:11px;color:var(--muted)">Prize Entries</div></div>
            </div>

            <div style="font-size:13px;font-weight:700;color:var(--navy);margin-bottom:6px">Logged Reading Inventory:</div>
            <div id="res-books-list" style="max-height:200px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--r);padding:6px;background:#fff"></div>
          </div>
          <div id="search-none" style="display:none;text-align:center;padding:15px;color:var(--muted);font-size:14px">No patron records match that library card.</div>
        </div>
      </div>
    </div>
  </div>
  
</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
import { getFirestore, doc, getDoc, setDoc, collection, getDocs, query, where, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

// ════════════════════════════════════════════════════════════
// CONFIGURATION — Obfuscated to pass Wix WAF filters safely
// ════════════════════════════════════════════════════════════
const _p = "summer-tracker-5c05d";
const firebaseConfig = {
  apiKey: ["AIzaSyC00nVY", "hJNlYOTo0s4C", "CFWpfxLKEfUiirk"].join(""),
  authDomain: _p + ".firebaseapp.com",
  projectId: _p,
  storageBucket: _p + ".firebasestorage.app",
  messagingSenderId: "144831474075",
  appId: "1:144831474075:web:8d1a2bdd7971199334193e",
  measurementId: "G-T7Q2599KJV"
};
// ════════════════════════════════════════════════════════════

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);

// HYBRID MODEL HELPERS ── ────────────────────────────────────
async function isAuthorizedStaff(uid) {
  if (!uid) return false;

  const staffSnap = await getDoc(doc(db, "staff", uid));
  return staffSnap.exists();
}

async function getCurrentYorkScores() {
  const [currentSnap, legacySnap] = await Promise.all([
    getDoc(doc(db, "york_scores", "current")),
    getDoc(doc(db, "york_scores", "1"))
  ]);

  if (currentSnap.exists()) return currentSnap;
  if (legacySnap.exists()) return legacySnap;
  return currentSnap;
}

async function getPatronDocByCard(card) {
  const directSnap = await getDoc(doc(db, "patrons", card));
  if (directSnap.exists()) return directSnap;

  const qPatron = query(collection(db, "patrons"), where("library_card", "==", card));
  const querySnap = await getDocs(qPatron);

  if (!querySnap.empty) {
    return querySnap.docs[0];
  }

  return null;
}

async function getPatronBooks(card, patronId) {
  const triedPaths = [];

  const subPaths = [
    ["patrons", card, "books"],
    patronId && patronId !== card ? ["patrons", patronId, "books"] : null
  ].filter(Boolean);

  for (const pathParts of subPaths) {
    try {
      triedPaths.push(pathParts.join("/"));
      const snap = await getDocs(collection(db, ...pathParts));
      if (!snap.empty) return snap;
    } catch (e) {
      // Try the next path.
    }
  }

  const legacyQueries = [
    query(collection(db, "books"), where("patron_id", "==", card))
  ];
  if (patronId && patronId !== card) {
    legacyQueries.push(query(collection(db, "books"), where("patron_id", "==", patronId)));
  }

  for (const q of legacyQueries) {
    try {
      const snap = await getDocs(q);
      if (!snap.empty) return snap;
    } catch (e) {
      // Try the next query.
    }
  }

  return null;
}

async function getPatronEntries(card, patronId) {
  const subPaths = [
    ["patrons", card, "basket_entries"],
    patronId && patronId !== card ? ["patrons", patronId, "basket_entries"] : null
  ].filter(Boolean);

  for (const pathParts of subPaths) {
    try {
      const snap = await getDocs(collection(db, ...pathParts));
      if (!snap.empty) return snap;
    } catch (e) {
      // Try the next path.
    }
  }

  const legacyQueries = [
    query(collection(db, "basket_entries"), where("patron_id", "==", card))
  ];
  if (patronId && patronId !== card) {
    legacyQueries.push(query(collection(db, "basket_entries"), where("patron_id", "==", patronId)));
  }

  for (const q of legacyQueries) {
    try {
      const snap = await getDocs(q);
      if (!snap.empty) return snap;
    } catch (e) {
      // Try the next query.
    }
  }

  return null;
}

function normalizeTimestamp(value) {
  if (!value) return null;
  if (typeof value.toDate === "function") return value.toDate();
  if (value.seconds) return new Date(value.seconds * 1000);
  return new Date(value);
}

function pickTotalBooksRead(patronData, booksSnap) {
  const stored = Number(patronData?.total_books_read);
  if (Number.isFinite(stored)) return stored;

  let total = 0;
  booksSnap?.forEach?.((bDoc) => {
    const b = bDoc.data();
    total += b.is_double_punch ? 2 : 1;
  });
  return total;
}

// ── STAFF CONSOLE SYSTEM ENGINE ──

async function processStaffLogin() {
  const email = document.getElementById('auth-email').value.trim();
  const pass = document.getElementById('auth-pass').value;
  const errEl = document.getElementById('auth-err');
  const btn = document.getElementById('btn-login');
  errEl.style.display = 'none';

  if (!email || !pass) {
    errEl.textContent = "Provide credential strings.";
    errEl.style.display = '';
    return;
  }

  try {
    btn.disabled = true;
    btn.textContent = 'Verifying...';

    const cred = await signInWithEmailAndPassword(auth, email, pass);

    const allowed = await isAuthorizedStaff(cred.user.uid);
    if (!allowed) {
      await signOut(auth);
      errEl.textContent = "Access denied. Staff record not found.";
      errEl.style.display = '';
      return;
    }

  } catch (err) {
    console.error(err);
    errEl.textContent = err?.code === 'auth/invalid-credential' || err?.code === 'auth/wrong-password'
      ? 'Authentication rejected. Invalid email or password.'
      : 'Authentication failed. Please try again.';
    errEl.style.display = '';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Verify Credentials';
  }
}

async function triggerYorkUpdate() {
  const books = parseInt(document.getElementById('york-books').value, 10);
  const readers = parseInt(document.getElementById('york-readers').value, 10);
  const okEl = document.getElementById('york-ok');
  const errEl = document.getElementById('york-err');
  okEl.style.display = 'none';
  errEl.style.display = 'none';

  if (isNaN(books) || isNaN(readers)) {
    errEl.textContent = "Provide accurate metric numerical figures.";
    errEl.style.display = '';
    return;
  }

  try {
    const payload = {
      books: books,
      readers: readers,
      updated_at: serverTimestamp()
    };

    await Promise.all([
      setDoc(doc(db, "york_scores", "current"), payload, { merge: true }),
      setDoc(doc(db, "york_scores", "1"), payload, { merge: true })
    ]);

    okEl.textContent = "Live metrics updated successfully!";
    okEl.style.display = '';
  } catch (e) {
    errEl.textContent = "Data execution drop. Check Firestore rule sets.";
    errEl.style.display = '';
  }
}

async function searchPatronRecord() {
  const card = document.getElementById('search-card').value.trim();
  const resBox = document.getElementById('search-results');
  const noneBox = document.getElementById('search-none');
  resBox.style.display = 'none';
  noneBox.style.display = 'none';

  if (!card) return;

  try {
    const patronDoc = await getPatronDocByCard(card);
    if (!patronDoc) {
      noneBox.style.display = 'block';
      return;
    }

    const patronId = patronDoc.id;
    const patronData = patronDoc.data() || {};
    const libraryCard = patronData.library_card || card;

    document.getElementById('res-name').textContent = patronData.display_name || '—';
    document.getElementById('res-card').textContent = `Card #${libraryCard}`;

    const [booksSnap, entriesSnap] = await Promise.all([
      getPatronBooks(libraryCard, patronId),
      getPatronEntries(libraryCard, patronId)
    ]);

    const booksArray = [];
    booksSnap?.forEach?.((bDoc) => {
      booksArray.push({
        id: bDoc.id,
        ...bDoc.data()
      });
    });

    booksArray.sort((a, b) => {
      const aTime = normalizeTimestamp(a.created_at || a.logged_at)?.getTime?.() || 0;
      const bTime = normalizeTimestamp(b.created_at || b.logged_at)?.getTime?.() || 0;
      return aTime - bTime;
    });

    const totalPunches = pickTotalBooksRead(patronData, booksSnap);

    // Secure UI update sequence avoiding .innerHTML parsing flags
    document.getElementById('res-punches').textContent = totalPunches;
    document.getElementById('res-entries').textContent = entriesSnap ? entriesSnap.size : 0;

    const listEl = document.getElementById('res-books-list');
    listEl.textContent = "";

    if (booksArray.length === 0) {
      const emptyDiv = document.createElement('div');
      emptyDiv.style.cssText = "color:var(--muted);padding:10px;text-align:center;font-size:12px";
      emptyDiv.textContent = "No books logged.";
      listEl.appendChild(emptyDiv);
    } else {
      booksArray.forEach((b) => {
        const itemDiv = document.createElement('div');
        itemDiv.className = "b-item";

        const leftDiv = document.createElement('div');
        leftDiv.textContent = "📚 ";
        
        const titleSpan = document.createElement('span');
        titleSpan.className = "b-title";
        titleSpan.textContent = b.title || '';
        leftDiv.appendChild(titleSpan);

        if (/\bred\b/i.test(b.title || "")) {
          const badge = document.createElement('span');
          badge.className = "badge badge-r";
          badge.textContent = "FLAG";
          leftDiv.appendChild(badge);
        } else if (/\bblue\b/i.test(b.title || "")) {
          const badge = document.createElement('span');
          badge.className = "badge badge-b";
          badge.textContent = "FLAG";
          leftDiv.appendChild(badge);
        }

        const rightDiv = document.createElement('div');
        rightDiv.style.cssText = "font-weight:600;color:var(--muted)";
        rightDiv.textContent = b.is_double_punch ? '2 punches' : '1 punch';

        itemDiv.appendChild(leftDiv);
        itemDiv.appendChild(rightDiv);
        listEl.appendChild(itemDiv);
      });
    }

    resBox.style.display = 'block';
  } catch (err) {
    alert("Record parse failure via operational restrictions.");
  }
}

const loginForm = document.getElementById('staff-login-form');

if (loginForm) {
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    await processStaffLogin();
  });
}

document.getElementById('btn-logout').addEventListener('click', async () => {
  await signOut(auth);
});

document.getElementById('btn-update-york').addEventListener('click', triggerYorkUpdate);
document.getElementById('btn-search-patron').addEventListener('click', searchPatronRecord);
document.getElementById('search-card').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    e.preventDefault();
    searchPatronRecord();
  }
});

onAuthStateChanged(auth, async (user) => {
  if (user) {
    try {
      const allowed = await isAuthorizedStaff(user.uid);
      if (allowed) {
        document.getElementById('page-auth').style.display = 'none';
        document.getElementById('page-main').style.display = 'block';

        const yorkSnap = await getCurrentYorkScores();
        if (yorkSnap && yorkSnap.exists()) {
          document.getElementById('york-books').value = yorkSnap.data().books || 0;
          document.getElementById('york-readers').value = yorkSnap.data().readers || 0;
        }
      } else {
        await signOut(auth);
      }
    } catch (err) {
      console.error(err);
      document.getElementById('page-main').style.display = 'none';
      document.getElementById('page-auth').style.display = 'block';
      const errEl = document.getElementById('auth-err');
      if (errEl) {
        errEl.textContent = 'Staff verification failed. Please try again.';
        errEl.style.display = '';
      }
    }
  } else {
    document.getElementById('page-main').style.display = 'none';
    document.getElementById('page-auth').style.display = 'block';
  }
});
</script>
</body>
</html>
